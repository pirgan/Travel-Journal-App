{
  "version": 2,
  "installCommand": "cd server && npm install && cd ../client && npm install",
  "buildCommand":   "cd client && npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
